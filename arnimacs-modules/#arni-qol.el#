;;; emacs
  ;; use-package declaration

(use-package emacs
  :config
  (require 'uniquify)
  (setq completion-styles			'(flex initials)
      	set-mark-command-repeat-pop		t ;; C-x C-SPC C-SPC C-SPC...
      	echo-keystrokes				0.01
      	desktop-path				'("~/.emacs.d/")
	backup-directory-alist                  '(("." . "~/.emacs.d/backups"))
      	initial-scratch-message			""
      	ring-bell-function			'ignore ;; no bell
      	register-use-preview			t
      	register-preview-delay			0
      	mark-ring-mark				16
      	uniquify-buffer-name-style		'forward
      	apropos-do-all				nil
      	read-file-name-completion-ignore-case	t
      	read-buffer-completion-ignore-case	t
      	completion-ignore-case			t
      	display-time-format			"%H:%M"
    	kill-whole-line				t
	view-read-only				t ;; read-only buffers call view-mode
	gc-cons-threshold                       #x40000000 ;; higher garbage collection threshold
	read-process-output-max                 (* 1024 1024 4) ;; maximum process output size for big data transfers
	initial-buffer-choice                   t
	disabled-command-function               nil) 
  (setq-default truncate-partial-width-windows          nil ;; if not set to nil, will override truncate-lines
		truncate-lines                          t
		display-line-numbers			'visual)
  (fset 'yes-or-no-p 'y-or-n-p) ;; yes or no in minibuffer becomes y or n. faster to type
  (tool-bar-mode 0)		;; ↓
  (scroll-bar-mode 0)		;; above 3 disable clickable help bars i do not need
  (fido-vertical-mode 1)	;; easier minibuffer completion
  (winner-mode 1)		;; revert window configurations easily
  (global-auto-revert-mode 1)	;; update buffer if file on system is changed outside of emacs
  (recentf-mode 1)		;; keep track of recently opened files on emacs
  (save-place-mode 1)		;; save point position on buffers, in between session
  (repeat-mode 1)		;; repeatable actions for less keystrokes
  (delete-selection-mode 1)	;; when region is active, typing or pressing DEL deletes entire region like in other editors
  (msb-mode 1)	                ;; Customizable mouse buffer menu, (info "(emacs) Buffer Menus")
  :bind
  (("C-+"	.	text-scale-increase)
   ("C-="	.	text-scale-decrease)
   ("C-."	.	repeat)
   ("C-%"	.	replace-regexp)
   ("C-<kp-equal>"	.	text-scale-decrease)
   ;; go/zap to char commands, i work a lot within single lines
   ("C-z"	.	arni/go-up-to-char)
   ("M-z"	.	zap-up-to-char)
   ("C-M-z"	.	zap-to-char)
   ("C-c k"	.	delete-window)
   ("C-c d"	.	dired-jump)
   ("C-c SPC"	.	tmm-menubar)
   ("C-c s"	.	arni/confirm-save-and-quit)
   ("C-c n"	.	arni/narrow-region-or-widen)
   ("C-c r"	.	arni/er-sudo-edit)
   ("C-x C-c"	.	nil) ;; same as above
   ("C-x C-q"	.	view-mode)
   ("C-x b"	.	consult-buffer)
   ("C-x k"	.	kill-current-buffer) ;; i just use ibuffer if i need to manage a lot of buffers
   ("C-x 4 b"	.	consult-buffer-other-window)
   ("C-x t b"	.	consult-buffer-other-tab)
   ("C-x 5 b"	.	consult-buffer-other-frame)
   ("C-x C-b"	.	ibuffer)
   ("M-("	.	beginning-of-buffer) ;; easier on azerty
   ("M-)"	.	end-of-buffer) ;; same here
   ("M-SPC"	.	mark-word)
   ("<mouse-9>"	.	next-buffer)
   ("<mouse-8>"	.	previous-buffer)
   :map			help-map
   ("C-k"	.	describe-keymap)))

;;; display-buffer-alist
(defun arni/dba-select-window (window)
  "A function to tell display-buffer-alist to
choose specific windows when opened."
  (select-window window))

(setq display-buffer-alist
      ;; when calling org-jump
      '(("\\*Org Help\\*"
	 (display-buffer-in-side-window)
	 (side . bottom)
	 (window-height . fit-window-to-buffer))
	;; register previews
	("\\*Register Preview\\*"
	 (display-buffer-reuse-mode-window display-buffer-in-side-window)
	 (side . bottom)
	 (window-height . fit-window-to-buffer))
	;; occur
	("\\*Occur\\*"
	 (display-buffer-in-side-window)
	 (window-height . 0.25)
	 (side . bottom)
	 (body-function . arni/dba-select-window))
	;; async shell command
	("\\*Async Shell Command\\*"
	 (display-buffer-in-side-window)
	 (window-height . 0.25)
	 (side . bottom))
	;; embark-act
	("\\*Embark Actions\\*"
	 (display-buffer-in-side-window)
	 (window-height . 0.25)
	 (side . bottom))
	;; completions
	("\\*Completions\\*"
	 (display-buffer-in-side-window)
	 (window-height . 0.25)
	 (side . bottom)
	 (body-function . arni/dba-select-window))
	("\\*grep\\*"
	 (display-buffer-in-side-window)
	 (window-height . 0.5)
	 (side . bottom)
	 (body-function . arni/dba-select-window))
	("\\*RE-Builder\\*"
	 (display-buffer-in-side-window)
	 (window-height . 0.25)
	 (side . bottom)
	 (body-function . arni/dba-select-window))
	;; default behavior. imagine this is like manual tiling WMs
	(".*"
	 (display-buffer-reuse-window display-buffer-same-window))))

