;;; arni-rice
;;; modus-themes
;; use-package declaration
(use-package modus-themes
  :config
  (setq modus-operandi-palette-overrides ;; https://protesilaos.com/emacs/modus-themes#h:34c7a691-19bb-4037-8d2f-67a07edab150
	'((comment red-faint))))

;; Conditional to apply the theme
(if (daemonp) 
    (add-hook 'after-make-frame-functions 
   	      (lambda (frame) 
   		(with-selected-frame frame (load-theme 'modus-operandi t))))
  (load-theme 'modus-operandi t))

;;; default-frame-alist
(setq default-frame-alist
      '((font . "Atkinson Hyperlegible Mono")
	(vertical-scroll-bars . nil)))

(use-package spacious-padding
  :init
  (setq spacious-padding-subtle-mode-line t)
  :config
  (spacious-padding-mode 1))

;;; My modeline configuration
(setq display-time-format "%H:%M"
      display-time-default-load-average nil)

(setq-default mode-line-format
      (list
       ;; start of modeline left part
       (propertize "'(" 'face '(:foreground "grey50"))
       ;; name of major mode
       "%m: "
       ;; buffer name
       "%b%&"
       (propertize ")" 'face '(:foreground "grey50"))
       ;; end of modeline left part
       'mode-line-format-right-align
       ;; start of modeline right part
       (propertize "'(" 'face '(:foreground "grey50"))
       ;; line number
       "%l . %c"
       ;; end of modeline
       (propertize ")" 'face '(:foreground "grey50"))))

(use-package doom-modeline)

